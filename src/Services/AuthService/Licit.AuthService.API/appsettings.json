{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/auth-service-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ],
    "Properties": {
      "Application": "Licit.AuthService"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Issuer": "Licit.AuthService",
    "Audience": "Licit.Client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "TwoFactorLogin": {
    "VerificationCodeExpirationMinutes": 5
  },
  "AuthVerification": {
    "RegisterVerificationCodeExpirationMinutes": 10,
    "PasswordResetCodeExpirationMinutes": 10,
    "MaxVerificationAttempts": 5
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=LicitDev2024!"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "licit",
    "Password": "LicitDev2024!"
  }
}
