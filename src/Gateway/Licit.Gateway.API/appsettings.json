{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "Redis": {
      "ConnectionString": "localhost:6379,password=LicitDev2024!",
      "KeyPrefix": "gateway:ratelimit"
    },
    "BypassPaths": [
      "/gateway",
      "/health"
    ],
    "Policies": [
      {
        "Name": "auth",
        "PathPrefix": "/api/auth",
        "PermitLimit": 5,
        "WindowSeconds": 60
      },
      {
        "Name": "api",
        "PathPrefix": "/api",
        "PermitLimit": 60,
        "WindowSeconds": 60
      },
      {
        "Name": "streamer",
        "PathPrefix": "/ws",
        "PermitLimit": 15,
        "WindowSeconds": 60
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "tendering-route": {
        "ClusterId": "tendering-cluster",
        "Match": {
          "Path": "/api/tender/{**catch-all}"
        }
      },
      "wallet-route": {
        "ClusterId": "wallet-cluster",
        "Match": {
          "Path": "/api/wallet/{**catch-all}"
        }
      },
      "mail-route": {
        "ClusterId": "mail-cluster",
        "Match": {
          "Path": "/api/email/{**catch-all}"
        }
      },
      "bidding-route": {
        "ClusterId": "bidding-cluster",
        "Match": {
          "Path": "/api/v1/{**catch-all}"
        }
      },
      "streamer-route": {
        "ClusterId": "streamer-cluster",
        "Match": {
          "Path": "/ws"
        }
      },
      "frontend-route": {
        "Order": 1000,
        "ClusterId": "frontend-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5122/"
          }
        }
      },
      "tendering-cluster": {
        "Destinations": {
          "tendering-service": {
            "Address": "http://localhost:5132/"
          }
        }
      },
      "wallet-cluster": {
        "Destinations": {
          "wallet-service": {
            "Address": "http://localhost:5142/"
          }
        }
      },
      "mail-cluster": {
        "Destinations": {
          "mail-service": {
            "Address": "http://localhost:5152/"
          }
        }
      },
      "bidding-cluster": {
        "Destinations": {
          "bidding-service": {
            "Address": "http://localhost:5160/"
          }
        }
      },
      "streamer-cluster": {
        "Destinations": {
          "streamer-service": {
            "Address": "http://localhost:5161/"
          }
        }
      },
      "frontend-cluster": {
        "Destinations": {
          "frontend-dev-server": {
            "Address": "http://localhost:5173/"
          }
        }
      }
    }
  }
}
